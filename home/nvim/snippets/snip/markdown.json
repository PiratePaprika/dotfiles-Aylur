{
  "h1": {
    "prefix": "h1",
    "body": ["# ${0}"]
  },
  "h2": {
    "prefix": "h2",
    "body": ["## ${0}"]
  },
  "h3": {
    "prefix": "h3",
    "body": ["### ${0}"]
  },
  "h4": {
    "prefix": "h4",
    "body": ["#### ${0}"]
  },
  "h5": {
    "prefix": "h5",
    "body": ["##### ${0}"]
  },
  "h6": {
    "prefix": "h6",
    "body": ["###### ${0}"]
  },
  "img": {
    "prefix": "img",
    "body": ["![${1:alt text}](${2:path}) ${0}"]
  },
  "code": {
    "prefix": "code",
    "body": ["```${1:language}", "$0", "```"]
  },
  "table": {
    "prefix": "table",
    "body": [
      "| ${1:Column1} | ${2:Column2} |",
      "| -------------- | --------------- |",
      "| ${3:Item1.1} | ${4:Item2.1} |",
      "${0}"
    ]
  },
  "note": {
    "prefix": "note",
    "body": "> [!NOTE]\n>\n> "
  },
  "tip": {
    "prefix": "tip",
    "body": "> [!TIP]\n>\n> "
  },
  "important": {
    "prefix": ["important", "imp"],
    "body": "> [!IMPORTANT]\n>\n> "
  },
  "warning": {
    "prefix": ["warning", "warn"],
    "body": "> [!WARNING]\n>\n> "
  },
  "caution": {
    "prefix": "caution",
    "body": "> [!CAUTION]\n>\n> "
  }
}
